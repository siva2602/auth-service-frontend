# Target: local (localhost API) or dev (remote API)
# local → http://localhost:8081
# dev   → http://18.134.155.144:8081
VITE_AUTH_TARGET=local

# Comma-separated — mirror backend CORS_ORIGINS for UI allowlist checks
VITE_CORS_ORIGINS=http://localhost:3000

# Platform header sent on every request (web for browser testing)
VITE_PLATFORM=web
